# 忽略指定项目依赖
AnimeSpeechGen/node_modules/

# 忽略数据库迁移文件（保留空目录结构）
AniVoiceBackend/migrations/*

# 忽略预训练模型目录（保留空目录结构）
AniVoiceBackend/pretrained_model

# 生成音频与本地参考音频
AniVoiceBackend/static/gen_audios/*.wav
AniVoiceBackend/static/ref_audios/**/*.wav
AniVoiceBackend/static/ref_audios/**/*.txt
!AniVoiceBackend/static/ref_audios/GenShin/furina-ref.wav
!AniVoiceBackend/static/ref_audios/GenShin/furina-ref.txt

# 通用开发环境排除项
*.log
*.pyc
*.sqlite
.env
AniVoiceBackend/.env
.venv
.DS_Store

# 编辑器/IDE 配置
.vscode/
.idea/
*.swp
*.swo

# 临时文件
*.tmp
*.bak

# 本地调试与运行期资源
.codex/
AniVoiceBackend/character_info.json
AniVoiceBackend/static/upload/
